rules_version = '2';

// Cousin Camp — Firebase Storage rules for the shared photo gallery.
// Photos live under camps/{campId}/photos, where campId is the SHA-256 hash of
// the family passcode. You need the passcode (and thus the campId) to reach a
// camp's photos, so read/write are open within a camp. A 10 MB per-file cap and
// an image-only check keep uploads sane and within the free tier.
service firebase.storage {
  match /b/{bucket}/o {
    match /camps/{campId}/photos/{fileName} {
      allow read: if true;
      allow write: if request.resource == null
                   || (request.resource.size < 10 * 1024 * 1024
                       && request.resource.contentType.matches('image/.*'));
    }
  }
}
